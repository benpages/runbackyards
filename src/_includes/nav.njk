<nav class="site-nav">
  <a href="/" class="brand">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M16.11 7.78 A6.5 6.5 0 1 1 14.18 5.02" stroke="white" stroke-width="4" stroke-linecap="butt"/>
    </svg>
    <span class="brand-wordmark">
      <span class="brand-b">BACKYARDS</span>
      <span class="brand-d" style="padding-left:0.25em;">.run</span>
    </span>
  </a>
  {% if navLabel %}
    <span class="sep">/</span>
    <span class="current">{{ navLabel }}</span>
  {% endif %}
  <div class="nav-right">
    <a href="/pace-tool/">Splits</a>
    <details class="nav-dropdown">
      <summary>Races</summary>
      <div class="nav-dropdown-menu">
        <a href="/races/bigs-2025/">Big's 2025</a>
        <a href="/races/g1m-2026/">Go One More 2026</a>
      </div>
    </details>
  </div>
</nav>

<script>
  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") {
      return;
    }

    document
      .querySelectorAll(".site-nav .nav-dropdown[open]")
      .forEach((dropdown) => {
        const summary = dropdown.querySelector("summary");
        dropdown.open = false;
        if (summary) {
          summary.focus();
        }
      });
  });
</script>
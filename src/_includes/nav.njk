<nav class="site-nav">
  <a href="/" class="brand">
    <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
      <path d="M11 2.2 A8.8 8.8 0 1 1 17.42 4.58" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
    </svg>
    <span class="brand-wordmark">
      <span class="brand-b">Backyards</span>
    </span>
  </a>
  <span class="sep">/</span>
  <span class="current">{{ title}}</span>
  <div class="nav-right">
    <a href="/pace-tool/">Pace Tool</a>
    <details class="nav-dropdown">
      <summary>Races</summary>
      <div class="nav-dropdown-menu">
        <a href="/races/bigs-2025/">Big's 2025</a>
        <a href="/races/g1m-2026/">Go One More 2026</a>
      </div>
    </details>
  </div>
</nav>

<script>
  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") {
      return;
    }

    document
      .querySelectorAll(".site-nav .nav-dropdown[open]")
      .forEach((dropdown) => {
        const summary = dropdown.querySelector("summary");
        dropdown.open = false;
        if (summary) {
          summary.focus();
        }
      });
  });
</script>

					<div class="fm-label">One drops. One finishes.</div>
				</div>
				<div class="fm-arrow">→</div>
				<div class="fm-step">
					<div class="fm-icon fm-icon--solo">+1</div>
					<div class="fm-label">Remaining runner must complete loop <em>N+1</em> alone</div>
				</div>

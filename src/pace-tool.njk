---
layout: base.njk
title: "Splits — backyards.run"
description: "Compare lap-by-lap splits across backyard ultra races. See who pushed, who faded, and how the field moved over 100+ loops."
navLabel: "Splits"
---

<div class="controls">
	<label for="raceSelect">Race</label>
	<select id="raceSelect"></select>
</div>

<div id="status" class="status">Loading race data…</div>

<main id="main" style="display: none">
	<div class="stats" id="statsRow"></div>
	<div class="card">
		<div class="card-title">Lap finish time (min) · by loop number</div>
		<div class="legend-bar">
			<input
						type="search"
						id="runnerSearch"
						placeholder="Find a runner…"
						autocomplete="off"
					/>
			<div class="quick-btns">
				<button class="qbtn" id="btnTop2">Top 2</button>
				<button class="qbtn" id="btnAll">Show all</button>
				<button class="qbtn" id="btnNone">Hide all</button>
			</div>
		</div>
		<div id="legend"></div>
		<div class="chart-wrap" style="margin-top: 1rem">
			<canvas id="chart" role="img" aria-label="Line chart of lap finish time by loop number."></canvas>
		</div>
	</div>
</main>

{% include "chart-scripts.njk" %}
<script>
	const RACES = [
		{
			id: "G1M_2026",
			label: "Go One More 2026",
			eventId: "390956",
			host: "my4",
			apiKey: "f545f563e8d28831fb09508cd63b1365",
			listname: "Lists|Detail List",
			page: "details1",
			startHour: 12
		},
		{
			id: "Bigs_2025",
			label: "Big's Backyard Ultra 2025",
			eventId: "364272",
			host: "my2",
			apiKey: "e35ba6322adb153e157d76e69096f692",
			listname: "Result Lists|Lap Details",
			page: "results",
			startHour: 7,
			extraParams: "&contest=0&r=all&l=0"
		}
	];

	window.BackyardCharts.createPaceTool({ races: RACES });
</script>


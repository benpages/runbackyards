			<input
						type="search"
						id="runnerSearch"
						placeholder="Find a runner…"
						autocomplete="off"
					/>
			<div class="quick-btns">
				<button class="qbtn" id="btnTop2">Top 2</button>
				<button class="qbtn" id="btnAll">Show all</button>
				<button class="qbtn" id="btnNone">Hide all</button>
			</div>
		</div>
		<div id="legend"></div>
		<div class="chart-wrap" style="margin-top: 1rem">
			<canvas id="chart" role="img" aria-label="Line chart of lap finish time by loop number."></canvas>
		</div>
	</div>
</main>

